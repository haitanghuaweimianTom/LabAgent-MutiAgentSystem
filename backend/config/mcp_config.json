{
  "mcpServers": {
    "web_search": {
      "command": "python",
      "args": [
        "/home/tomgame/projects/MathModel-MutiAgentSystem/backend/app/mcp/web_search_server.py"
      ],
      "env": {}
    },
    "file_system": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "./workspace",
        "./output"
      ],
      "env": {}
    },
    "arxiv_server": {
      "command": "/home/tomgame/.local/bin/uvx",
      "args": [
        "--from",
        "arxiv-mcp-server",
        "arxiv-mcp-server"
      ],
      "env": {}
    }
  },
  "tools": {
    "web_search": {
      "server": "web_search",
      "description": "DuckDuckGo 搜索（免费，无需 API Key）"
    },
    "bing_search": {
      "server": "web_search",
      "description": "Bing 搜索（免费，无需 API Key）"
    },
    "wechat_search": {
      "server": "web_search",
      "description": "微信公众号文章搜索（通过搜狗，免费）"
    },
    "arxiv_search": {
      "server": "arxiv_server",
      "description": "arXiv 论文搜索"
    },
    "arxiv_download": {
      "server": "arxiv_server",
      "description": "下载 arXiv 论文 PDF"
    },
    "arxiv_abstract": {
