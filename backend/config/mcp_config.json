{
  "mcpServers": {
    "web_search": {
      "command": "npx",
      "args": [
        "-y",
        "@nachoretro/internetsearch"
      ],
      "env": {}
    },
    "file_system": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "./workspace",
        "./output"
      ],
      "env": {}
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": ""
      }
    },
    "scholarly_research": {
      "command": "npx",
      "args": [
        "-y",
        "scholarly-research-mcp"
      ],
      "env": {}
    },
    "arxiv_server": {
      "command": "/home/tomgame/.local/bin/uvx",
      "args": [
        "--from",
        "arxiv-mcp-server",
        "arxiv-mcp-server"
      ],
      "env": {}
    }
  },
  "tools": {
    "web_search": {
      "server": "web_search",
      "description": "内置工具: web_search"
    },
    "paper_search": {
      "server": "scholarly_research",
      "description": "内置工具: paper_search"
    },
    "arxiv_search": {
      "server": "arxiv_server",
      "description": "内置工具: arxiv_search"
    },
    "scholar_search": {
      "server": "scholarly_research",
      "description": "内置工具: scholar_search"
    },
    "arxiv_download": {
      "server": "arxiv_server",
      "description": "内置工具: arxiv_download"
    },
    "arxiv_abstract": {
      "server": "arxiv_server",
      "description": "内置工具: arxiv_abstract"
    },
    "arxiv_citation": {
      "server": "arxiv_server",
      "description": "内置工具: arxiv_citation"
    },
    "file_read": {
      "server": "file_system",
      "description": "内置工具: file_read"
    },
    "file_write": {
      "server": "file_system",
      "description": "内置工具: file_write"
    },
    "code_execute": {
      "server": "file_system",
      "description": "内置工具: code_execute"
    },
    "latex_compile": {
      "server": "file_system",
      "description": "内置工具: latex_compile"
    }
  },
  "agent_tools": {
    "research_agent": [
      "web_search",
      "paper_search",
      "arxiv_search",
      "arxiv_download",
      "arxiv_abstract",
      "arxiv_citation",
      "scholar_search",
      "file_read",
      "file_write"
    ],
    "analyzer_agent": [
      "web_search",
      "paper_search",
      "sequentialthinking",
      "arxiv_search",
      "arxiv_abstract",
      "scholar_search",
      "file_read",
      "file_write"
    ],
    "modeler_agent": [
      "web_search",
      "paper_search",
      "arxiv_search",
      "sequentialthinking",
      "scholar_search",
      "file_read",
      "file_write"
    ],
    "solver_agent": [
      "web_search",
      "paper_search",
      "file_read",
      "file_write",
      "code_execute"
    ],
    "writer_agent": [
      "web_search",
      "paper_search",
      "file_read",
      "file_write",
      "arxiv_abstract",
      "latex_compile"
    ],
    "data_agent": [
      "web_search",
      "paper_search",
