# 数学建模多Agent系统 - 环境变量配置示例
# 请根据你的 Provider 配置修改以下变量

# 通用 API 配置（兼容旧 MINIMAX_API_KEY）
API_KEY=your_api_key_here
MINIMAX_API_KEY=your_api_key_here

# API 基础地址（根据你的 Provider 修改）
API_BASE_URL=https://api.openai.com/v1

# 默认模型配置（根据你的 Provider 修改）
DEFAULT_MODEL=gpt-4o
FALLBACK_MODEL=gpt-4o-mini

# 应用配置
DEBUG=false
APP_NAME=数学建模多Agent系统
APP_VERSION=3.0.0

# CORS配置（逗号分隔）
CORS_ORIGINS=*

# 数据库配置
DATABASE_URL=sqlite:///./data/agents.db

# Redis配置（可选）
REDIS_URL=redis://localhost:6379

# MCP服务器配置
MCP_SERVERS_PATH=./config/mcp_config.json

# 输出目录
OUTPUT_DIR=./output

# ===== 多 Provider 示例（取消注释并填写即可使用）=====
# ANTHROPIC_API_KEY=your_anthropic_key
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OPENAI_API_KEY=your_openai_key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# GEMINI_API_KEY=your_gemini_key
# GEMINI_MODEL=gemini-2.5-pro

# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:latest

# 默认 LLM Provider（留空则自动检测）
DEFAULT_LLM_PROVIDER=
